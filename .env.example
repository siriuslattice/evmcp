# RPC Provider — Alchemy key covers all chains (REQUIRED: at least this OR individual URLs)
ALCHEMY_API_KEY=

# Individual chain overrides (optional — override Alchemy for specific chains)
ETHEREUM_RPC_URL=               # Ethereum L1 (for ENS only)
BASE_RPC_URL=
OPTIMISM_RPC_URL=
AVALANCHE_RPC_URL=
CELO_RPC_URL=
ARBITRUM_RPC_URL=

# Block explorer API keys (optional)
ARBISCAN_KEY=

# Cache (optional)
CACHE_TTL_SECONDS=15
CACHE_MAX_ENTRIES=1000

# Logging (optional)
LOG_LEVEL=info                   # debug | info | warn | error

# Network mode (optional)
USE_TESTNETS=false

# Transport (optional)
TRANSPORT=stdio                      # stdio | http
HTTP_PORT=3402                       # Port for HTTP transport

# x402 Payment Gating (HTTP transport only)
X402_ENABLED=false
X402_PAYEE_ADDRESS=                  # USDC receive address on Base (0x...)
X402_FACILITATOR_URL=https://facilitator.x402.org

# Admin only — used by scripts/admin.ts, NEVER by the MCP server process
DEPLOYER_PRIVATE_KEY=            # 0x-prefixed — only in .env, never committed
