{
  "name": "evmcp",
  "version": "0.1.0",
  "description": "MCP server for multi-chain EVM blockchain data with companion smart contracts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "evmcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector node build/index.js",
    "check-rpcs": "tsx scripts/check-rpcs.ts",
    "refresh-cache": "tsx scripts/refresh-cache.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blockchain",
    "ethereum",
    "base",
    "optimism",
    "avalanche",
    "celo",
    "ai",
    "llm",
    "web3",
    "evm",
    "cross-chain"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SiriusLattice/evmcp.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^16.4.0",
    "viem": "^2.39.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.7.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
