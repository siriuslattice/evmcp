{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.siriuslattice/evmcp",
  "version": "0.1.3",
  "description": "Multi-chain EVM blockchain data with companion smart contracts",
  "repository": {
    "url": "https://github.com/SiriusLattice/evmcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "evmcp",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Alchemy API key for RPC access",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ALCHEMY_API_KEY"
        }
      ]
    },
    {
      "registryType": "npm",
      "identifier": "evmcp",
      "version": "0.2.0",
      "transport": {
        "type": "streamableHttp",
        "url": "http://localhost:3402/mcp"
      },
      "environmentVariables": [
        {
          "description": "Alchemy API key for RPC access",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ALCHEMY_API_KEY"
        },
        {
          "description": "Set to 'http' for HTTP transport",
          "isRequired": true,
          "format": "string",
          "name": "TRANSPORT"
        },
        {
          "description": "HTTP port (default 3402)",
          "isRequired": false,
          "format": "number",
          "name": "HTTP_PORT"
        }
      ]
    }
  ]
}
